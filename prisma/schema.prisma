// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Vendor {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  email        String   @unique
  passwordHash String
  logoUrl      String?
  primaryColor String   @default("#2563eb")
  ctaColor     String   @default("#f97316")
  timezone     String   @default("Asia/Taipei")
  supportEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members                    VendorMember[]
  tracking                   TrackingSetting?
  videos                     Video[]
  products                   Product[]
  forms                      RegistrationForm[]
  lives                      Live[]
  templates                  MessageTemplate[]
  analytics                  AnalyticsEvent[]
  interactionScripts         InteractionScript[]
  interactionRoles           InteractionRole[]
  blacklists                 Blacklist[]
  affiliates                 Affiliate[]
  affiliateClicks            AffiliateClick[]
  affiliateCommissions       AffiliateCommission[]
  affiliatePayouts           AffiliatePayout[]
  usageRecords               UsageRecord[]
  usageLimit                 VendorUsageLimit?
  subscriptions              VendorSubscription[]
  invoices                   Invoice[]
  settlements                Settlement[]
  payoutItems                PayoutItem[]
  paymentAccounts            PaymentAccount[]
  paymentTransactions        PaymentTransaction[]
  refundRecords              RefundRecord[]
  auditLogs                  AuditLog[]
  webhookEvents              WebhookEvent[]
  sessions                   UserSession[]
  salesTeams                 SalesTeam[]
  teamTemplates              TeamFunnelTemplate[]
  teamTemplateVersions       TeamFunnelTemplateVersion[]
  partnerFunnelPages         PartnerFunnelPage[]
  teamClickAttributions      TeamClickAttribution[]
  teamLeadAttributions       TeamLeadAttribution[]
  teamConversionAttributions TeamConversionAttribution[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  platformRole String    @default("none")
  status       String    @default("active")
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberships         VendorMember[]
  sessions            UserSession[]
  passwordResetTokens PasswordResetToken[]
  mfaFactor           UserMfaFactor?
  recoveryCodes       UserRecoveryCode[]
}

model UserSession {
  id            String    @id @default(cuid())
  userId        String
  vendorId      String?
  tokenHash     String    @unique
  ipAddress     String?
  userAgent     String?
  mfaVerifiedAt DateTime?
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([userId, expiresAt])
  @@index([vendorId, expiresAt])
  @@index([expiresAt])
}

model UserMfaFactor {
  id              String    @id @default(cuid())
  userId          String    @unique
  factorType      String    @default("totp")
  label           String?
  secretEncrypted String
  enabledAt       DateTime  @default(now())
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([factorType, enabledAt])
}

model UserRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model VendorMember {
  id            String    @id @default(cuid())
  vendorId      String
  userId        String
  role          String    @default("owner")
  status        String    @default("active")
  deactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  teamMemberships             TeamMembership[]
  createdTeamTemplateVersions TeamFunnelTemplateVersion[]   @relation("TeamTemplateVersionCreatedBy")
  templateFieldLocks          TeamFunnelTemplateFieldLock[]

  @@unique([vendorId, userId])
  @@unique([vendorId, id])
  @@index([vendorId, status])
}

model TrackingSetting {
  id                  String   @id @default(cuid())
  vendorId            String   @unique
  facebookPixelId     String?
  tiktokPixelId       String?
  googleTagManagerId  String?
  enablePageView      Boolean  @default(true)
  enableLeadEvent     Boolean  @default(true)
  enablePurchaseEvent Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Video {
  id                      String   @id @default(cuid())
  vendorId                String
  title                   String
  description             String?
  sourceType              String   @default("cloudflare_stream")
  videoUrl                String
  thumbnailUrl            String?
  durationSec             Int      @default(0)
  status                  String   @default("ready")
  cloudflareStreamUid     String?
  cloudflareLiveInputUid  String?
  cloudflarePlaybackId    String?
  cloudflareReadyToStream Boolean  @default(false)
  liveStreamKey           String?
  liveInputStatus         String?
  estimatedMinutes        Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  lives  Live[]
}

model Product {
  id             String   @id @default(cuid())
  vendorId       String
  name           String
  slug           String   @unique
  description    String?
  priceCents     Int
  compareAtCents Int?
  currency       String   @default("TWD")
  imageUrl       String?
  checkoutUrl    String?
  inventory      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendor                  Vendor                          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  liveProducts            LiveProduct[]
  templateProductSlots    TeamFunnelTemplateProductSlot[]
  partnerProductOverrides PartnerProductSlotOverride[]

  @@unique([vendorId, id])
}

model RegistrationForm {
  id             String   @id @default(cuid())
  vendorId       String
  name           String
  slug           String   @unique
  headline       String
  description    String?
  submitLabel    String   @default("送出報名")
  fields         Json
  successMessage String   @default("已收到你的資料，開播前會再提醒你。")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vendor      Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]
  lives       Live[]
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  liveId    String?
  name      String
  email     String
  phone     String?
  answers   Json?
  source    String   @default("form")
  createdAt DateTime @default(now())

  form            RegistrationForm     @relation(fields: [formId], references: [id], onDelete: Cascade)
  live            Live?                @relation(fields: [liveId], references: [id], onDelete: SetNull)
  teamAttribution TeamLeadAttribution?
}

model Live {
  id                       String   @id @default(cuid())
  vendorId                 String
  videoId                  String?
  formId                   String?
  messageTemplateId        String?
  interactionScriptId      String?
  teamId                   String?
  seminarOwnerMembershipId String?
  title                    String
  slug                     String   @unique
  description              String?
  scheduledAt              DateTime
  status                   String   @default("draft")
  heroImageUrl             String?
  accentCopy               String?
  replayEnabled            Boolean  @default(true)
  streamMode               String   @default("vod")
  cloudflareLiveInputUid   String?
  quotaPolicy              Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  vendor             Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  video              Video?              @relation(fields: [videoId], references: [id], onDelete: SetNull)
  form               RegistrationForm?   @relation(fields: [formId], references: [id], onDelete: SetNull)
  messageTemplate    MessageTemplate?    @relation(fields: [messageTemplateId], references: [id], onDelete: SetNull)
  interactionScript  InteractionScript?  @relation(fields: [interactionScriptId], references: [id], onDelete: SetNull)
  team               SalesTeam?          @relation(fields: [vendorId, teamId], references: [vendorId, id], onDelete: Restrict)
  seminarOwner       TeamMembership?     @relation("LiveSeminarOwner", fields: [teamId, seminarOwnerMembershipId], references: [teamId, id], onDelete: Restrict)
  products           LiveProduct[]
  submissions        FormSubmission[]
  analytics          AnalyticsEvent[]
  affiliateClicks    AffiliateClick[]
  partnerFunnelPages PartnerFunnelPage[]

  @@unique([vendorId, id])
}

model LiveProduct {
  id         String  @id @default(cuid())
  liveId     String
  productId  String
  sortOrder  Int     @default(0)
  offerLabel String?
  isPinned   Boolean @default(false)

  live    Live    @relation(fields: [liveId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([liveId, productId])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  vendorId  String
  name      String
  channel   String   @default("email")
  trigger   String   @default("registration_confirmed")
  subject   String?
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  lives  Live[]
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  vendorId  String
  liveId    String?
  eventType String
  visitorId String
  payload   Json?
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  live   Live?  @relation(fields: [liveId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([liveId, createdAt])
}

model InteractionRole {
  id        String   @id @default(cuid())
  vendorId  String
  name      String
  avatarUrl String?
  label     String   @default("官方角色")
  roleType  String   @default("official")
  tone      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  events InteractionEvent[]
}

model InteractionScript {
  id          String   @id @default(cuid())
  vendorId    String
  name        String
  description String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  events InteractionEvent[]
  lives  Live[]
}

model InteractionEvent {
  id         String   @id @default(cuid())
  scriptId   String
  roleId     String?
  eventType  String
  triggerSec Int      @default(0)
  title      String
  message    String?
  productId  String?
  ctaLabel   String?
  ctaUrl     String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  script InteractionScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  role   InteractionRole?  @relation(fields: [roleId], references: [id], onDelete: SetNull)
}

model Blacklist {
  id             String    @id @default(cuid())
  vendorId       String
  identifier     String
  identifierType String    @default("email")
  reason         String
  notes          String?
  isActive       Boolean   @default(true)
  blockedAt      DateTime  @default(now())
  unblockedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, identifier])
}

model Affiliate {
  id                String   @id @default(cuid())
  vendorId          String
  name              String
  code              String   @unique
  source            String?
  contactEmail      String?
  commissionRateBps Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  vendor          Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  clicks          AffiliateClick[]
  commissions     AffiliateCommission[]
  payouts         AffiliatePayout[]
  teamMemberships TeamMembership[]

  @@unique([vendorId, id])
}

model AffiliateClick {
  id           String    @id @default(cuid())
  vendorId     String
  affiliateId  String?
  liveId       String?
  referralCode String?
  visitorId    String
  landingPath  String
  convertedAt  DateTime?
  createdAt    DateTime  @default(now())

  vendor          Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  affiliate       Affiliate?            @relation(fields: [affiliateId], references: [id], onDelete: SetNull)
  live            Live?                 @relation(fields: [liveId], references: [id], onDelete: SetNull)
  teamAttribution TeamClickAttribution?

  @@unique([vendorId, id])
  @@index([referralCode, createdAt])
  @@index([liveId, createdAt])
}

model BillingPlan {
  id                              String   @id @default(cuid())
  name                            String
  code                            String   @unique
  monthlyPriceCents               Int      @default(0)
  includedStreamMinutes           Int      @default(0)
  includedStorageMinutes          Int      @default(0)
  includedCredits                 Int      @default(0)
  includedEvents                  Int      @default(0)
  includedAffiliates              Int      @default(0)
  overageCreditCostCents          Int      @default(0)
  overflowWatchHourPriceCents     Int      @default(0)
  overflowEventUnitPriceCents     Int      @default(0)
  overflowAffiliateUnitPriceCents Int      @default(0)
  overflowStorageMinutePriceCents Int      @default(0)
  paymentServiceFeeCents          Int      @default(0)
  transactionFeeRateBps           Int      @default(0)
  affiliateManagementFeeCents     Int      @default(0)
  isActive                        Boolean  @default(true)
  description                     String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  usageLimits   VendorUsageLimit[]
  subscriptions VendorSubscription[]
}

model VendorSubscription {
  id               String    @id @default(cuid())
  vendorId         String
  planId           String
  paymentMode      String    @default("byo")
  status           String    @default("active")
  customFeeRateBps Int?
  billingCycleDay  Int       @default(5)
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  vendor Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  plan   BillingPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([vendorId, status])
}

model VendorUsageLimit {
  id                  String   @id @default(cuid())
  vendorId            String   @unique
  billingPlanId       String?
  streamMinutesLimit  Int      @default(0)
  storageMinutesLimit Int      @default(0)
  creditsLimit        Int      @default(0)
  streamMinutesUsed   Int      @default(0)
  storageMinutesUsed  Int      @default(0)
  creditsUsed         Int      @default(0)
  resetAt             DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  vendor      Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  billingPlan BillingPlan? @relation(fields: [billingPlanId], references: [id], onDelete: SetNull)
}

model UsageRecord {
  id                     String   @id @default(cuid())
  vendorId               String
  monthKey               String?
  recordType             String
  quantity               Int
  unit                   String
  creditsDelta           Int      @default(0)
  totalWatchMinutes      Int      @default(0)
  totalEvents            Int      @default(0)
  totalAffiliates        Int      @default(0)
  totalStorageMinutes    Int      @default(0)
  overflowWatchMinutes   Int      @default(0)
  overflowEvents         Int      @default(0)
  overflowAffiliates     Int      @default(0)
  overflowStorageMinutes Int      @default(0)
  description            String?
  metadata               Json?
  createdAt              DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, monthKey])
  @@index([vendorId, createdAt])
  @@index([recordType, createdAt])
}

model Invoice {
  id                          String    @id @default(cuid())
  vendorId                    String
  monthKey                    String
  invoiceNumber               String    @unique
  invoiceType                 String    @default("monthly")
  monthlyFeeCents             Int       @default(0)
  overflowFeeCents            Int       @default(0)
  paymentServiceFeeCents      Int       @default(0)
  transactionServiceFeeCents  Int       @default(0)
  affiliateManagementFeeCents Int       @default(0)
  subtotalCents               Int       @default(0)
  taxCents                    Int       @default(0)
  totalCents                  Int       @default(0)
  status                      String    @default("draft")
  dueAt                       DateTime?
  paidAt                      DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, monthKey])
}

model Settlement {
  id                          String    @id @default(cuid())
  vendorId                    String
  monthKey                    String
  monthlyFeeCents             Int       @default(0)
  overflowFeeCents            Int       @default(0)
  paymentServiceFeeCents      Int       @default(0)
  transactionServiceFeeCents  Int       @default(0)
  affiliateManagementFeeCents Int       @default(0)
  paymentGatewayFeeCents      Int       @default(0)
  grossRevenueCents           Int       @default(0)
  payoutableAmountCents       Int       @default(0)
  adjustmentAmountCents       Int       @default(0)
  adjustmentReason            String?
  finalPayoutAmountCents      Int       @default(0)
  status                      String    @default("draft")
  lockedAt                    DateTime?
  lockedBy                    String?
  paidAt                      DateTime?
  reviewedBy                  String?
  payoutBatchId               String?
  payoutDate                  DateTime?
  batchNumber                 String?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  vendor      Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  payoutBatch PayoutBatch? @relation(fields: [payoutBatchId], references: [id], onDelete: SetNull)
  payoutItems PayoutItem[]

  @@unique([vendorId, monthKey])
  @@index([status, monthKey])
}

model PayoutBatch {
  id               String    @id @default(cuid())
  batchNumber      String    @unique
  batchDate        DateTime
  totalAmountCents Int       @default(0)
  totalCount       Int       @default(0)
  status           String    @default("draft")
  exportedFilePath String?
  exportedAt       DateTime?
  executedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  settlements Settlement[]
  items       PayoutItem[]
}

model PayoutItem {
  id                String    @id @default(cuid())
  payoutBatchId     String
  vendorId          String
  settlementId      String?
  bankAccountName   String
  bankCode          String
  bankAccountNumber String
  payoutAmountCents Int
  status            String    @default("pending")
  failReason        String?
  paidAt            DateTime?
  retryCount        Int       @default(0)
  retriedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  payoutBatch PayoutBatch @relation(fields: [payoutBatchId], references: [id], onDelete: Cascade)
  vendor      Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  settlement  Settlement? @relation(fields: [settlementId], references: [id], onDelete: SetNull)

  @@index([payoutBatchId, status])
  @@index([vendorId, createdAt])
}

model PaymentAccount {
  id                String   @id @default(cuid())
  vendorId          String
  mode              String   @default("byo")
  providerName      String
  accountLabel      String
  status            String   @default("pending")
  apiKeyRef         String?
  merchantIdRef     String?
  bankAccountName   String?
  bankCode          String?
  bankAccountNumber String?
  riskHoldEnabled   Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, mode])
}

model PaymentTransaction {
  id                  String    @id @default(cuid())
  vendorId            String
  providerName        String
  providerTradeNo     String?
  orderNumber         String?
  paymentMode         String    @default("platform")
  grossAmountCents    Int       @default(0)
  gatewayFeeCents     Int       @default(0)
  platformFeeCents    Int       @default(0)
  netAmountCents      Int       @default(0)
  currency            String    @default("TWD")
  status              String    @default("paid")
  refundedAmountCents Int       @default(0)
  refundReason        String?
  refundedAt          DateTime?
  occurredAt          DateTime  @default(now())
  metadata            Json?
  createdAt           DateTime  @default(now())

  vendor          Vendor                     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  refunds         RefundRecord[]
  teamAttribution TeamConversionAttribution?

  @@unique([vendorId, id])
  @@index([vendorId, occurredAt])
  @@index([vendorId, orderNumber])
  @@index([status, occurredAt])
}

model WebhookEvent {
  id           String    @id @default(cuid())
  vendorId     String?
  provider     String
  eventId      String
  eventType    String
  status       String    @default("received")
  payload      Json
  errorMessage String?
  processedAt  DateTime?
  retryCount   Int       @default(0)
  maxRetries   Int       @default(5)
  nextRetryAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
  @@index([status, createdAt])
  @@index([vendorId, createdAt])
}

model RefundRecord {
  id                     String   @id @default(cuid())
  vendorId               String
  paymentTransactionId   String
  providerEventId        String?
  monthKey               String
  refundAmountCents      Int
  gatewayFeeRefundCents  Int      @default(0)
  platformFeeRefundCents Int      @default(0)
  reason                 String?
  status                 String   @default("processed")
  processedAt            DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  vendor             Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  paymentTransaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)

  @@index([vendorId, monthKey])
  @@index([paymentTransactionId, processedAt])
  @@index([paymentTransactionId, providerEventId])
}

model AuditLog {
  id         String   @id @default(cuid())
  vendorId   String?
  actorId    String?
  actorLabel String?
  action     String
  targetType String
  targetId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([vendorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

model AffiliateCommission {
  id                    String    @id @default(cuid())
  vendorId              String
  affiliateId           String?
  monthKey              String
  sourceType            String    @default("product")
  sourceId              String?
  referralCode          String?
  orderNumber           String?
  orderAmountCents      Int       @default(0)
  commissionRateBps     Int       @default(0)
  commissionAmountCents Int       @default(0)
  status                String    @default("pending")
  attributedAt          DateTime  @default(now())
  settledAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  vendor    Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  affiliate Affiliate? @relation(fields: [affiliateId], references: [id], onDelete: SetNull)

  @@index([vendorId, monthKey])
  @@index([affiliateId, status])
}

model AffiliatePayout {
  id                    String    @id @default(cuid())
  vendorId              String
  affiliateId           String?
  monthKey              String
  commissionAmountCents Int       @default(0)
  adjustmentAmountCents Int       @default(0)
  finalAmountCents      Int       @default(0)
  status                String    @default("pending")
  payoutItemId          String?
  paidAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  vendor    Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  affiliate Affiliate? @relation(fields: [affiliateId], references: [id], onDelete: SetNull)

  @@index([vendorId, monthKey])
  @@index([affiliateId, status])
}

enum TeamMembershipStatus {
  ACTIVE
  INACTIVE
}

enum TeamFunnelTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum TeamFunnelField {
  HEADLINE
  SUBHEADLINE
  BODY
  CTA_LABEL
  CTA_URL
  PRODUCT_SLOTS
}

enum TeamPageAccessMode {
  PUBLIC
  TOKEN_REQUIRED
  DISABLED
}

enum TeamAttributionSource {
  REFERRAL
  EXISTING_OWNER
  MANUAL_OVERRIDE
  DIRECT
}

model SalesTeam {
  id        String   @id @default(cuid())
  vendorId  String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor                 Vendor                       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  memberships            TeamMembership[]
  templates              TeamFunnelTemplate[]
  templateVersions       TeamFunnelTemplateVersion[]
  webinars               Live[]
  partnerFunnelPages     PartnerFunnelPage[]
  clickAttributions      TeamClickAttribution[]
  leadAttributions       TeamLeadAttribution[]
  conversionAttributions TeamConversionAttribution[]
  relationships          TeamMembershipRelationship[]

  @@unique([vendorId, slug])
  @@unique([vendorId, id])
}

model TeamMembership {
  id             String               @id @default(cuid())
  vendorId       String
  teamId         String
  vendorMemberId String
  affiliateId    String?
  status         TeamMembershipStatus @default(ACTIVE)
  joinedAt       DateTime             @default(now())
  leftAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  team                                 SalesTeam                    @relation(fields: [vendorId, teamId], references: [vendorId, id], onDelete: Cascade)
  vendorMember                         VendorMember                 @relation(fields: [vendorId, vendorMemberId], references: [vendorId, id], onDelete: Restrict)
  affiliate                            Affiliate?                   @relation(fields: [vendorId, affiliateId], references: [vendorId, id], onDelete: Restrict)
  downlineRelationships                TeamMembershipRelationship[] @relation("TeamRelationshipUpline")
  uplineRelationships                  TeamMembershipRelationship[] @relation("TeamRelationshipDownline")
  contentOwnedTemplateVersions         TeamFunnelTemplateVersion[]  @relation("TeamTemplateVersionContentOwner")
  ownedWebinars                        Live[]                       @relation("LiveSeminarOwner")
  promotedPages                        PartnerFunnelPage[]          @relation("PartnerPagePromoter")
  contentOwnedPages                    PartnerFunnelPage[]          @relation("PartnerPageContentOwner")
  clickAttributionsAsLeader            TeamClickAttribution[]       @relation("ClickAttributionLeader")
  clickAttributionsAsPromoter          TeamClickAttribution[]       @relation("ClickAttributionPromoter")
  clickAttributionsAsContentOwner      TeamClickAttribution[]       @relation("ClickAttributionContentOwner")
  clickAttributionsAsSeminarOwner      TeamClickAttribution[]       @relation("ClickAttributionSeminarOwner")
  leadAttributionsAsLeader             TeamLeadAttribution[]        @relation("LeadAttributionLeader")
  leadAttributionsAsPromoter           TeamLeadAttribution[]        @relation("LeadAttributionPromoter")
  leadAttributionsAsContentOwner       TeamLeadAttribution[]        @relation("LeadAttributionContentOwner")
  leadAttributionsAsSeminarOwner       TeamLeadAttribution[]        @relation("LeadAttributionSeminarOwner")
  conversionAttributionsAsLeader       TeamConversionAttribution[]  @relation("ConversionAttributionLeader")
  conversionAttributionsAsPromoter     TeamConversionAttribution[]  @relation("ConversionAttributionPromoter")
  conversionAttributionsAsContentOwner TeamConversionAttribution[]  @relation("ConversionAttributionContentOwner")
  conversionAttributionsAsSeminarOwner TeamConversionAttribution[]  @relation("ConversionAttributionSeminarOwner")

  @@unique([teamId, vendorMemberId])
  @@unique([vendorId, affiliateId])
  @@unique([teamId, id])
  @@index([vendorId, vendorMemberId, status])
  @@index([teamId, status])
}

model TeamMembershipRelationship {
  id                   String    @id @default(cuid())
  teamId               String
  uplineMembershipId   String
  downlineMembershipId String
  effectiveAt          DateTime  @default(now())
  endedAt              DateTime?
  createdAt            DateTime  @default(now())

  team     SalesTeam      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  upline   TeamMembership @relation("TeamRelationshipUpline", fields: [teamId, uplineMembershipId], references: [teamId, id], onDelete: Restrict)
  downline TeamMembership @relation("TeamRelationshipDownline", fields: [teamId, downlineMembershipId], references: [teamId, id], onDelete: Restrict)

  @@unique([downlineMembershipId, effectiveAt])
  @@index([teamId, uplineMembershipId, endedAt])
  @@index([teamId, downlineMembershipId, endedAt])
}

model TeamFunnelTemplate {
  id        String                   @id @default(cuid())
  vendorId  String
  teamId    String
  name      String
  status    TeamFunnelTemplateStatus @default(DRAFT)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  vendor   Vendor                      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  team     SalesTeam                   @relation(fields: [vendorId, teamId], references: [vendorId, id], onDelete: Cascade)
  versions TeamFunnelTemplateVersion[]

  @@unique([teamId, name])
  @@unique([teamId, id])
  @@index([vendorId, status])
}

model TeamFunnelTemplateVersion {
  id                       String   @id @default(cuid())
  vendorId                 String
  teamId                   String
  templateId               String
  version                  Int
  contentOwnerMembershipId String
  createdByMemberId        String
  headline                 String
  subheadline              String?
  body                     String?
  ctaLabel                 String
  ctaUrl                   String?
  createdAt                DateTime @default(now())

  vendor             Vendor                          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  team               SalesTeam                       @relation(fields: [vendorId, teamId], references: [vendorId, id], onDelete: Cascade)
  template           TeamFunnelTemplate              @relation(fields: [teamId, templateId], references: [teamId, id], onDelete: Cascade)
  contentOwner       TeamMembership                  @relation("TeamTemplateVersionContentOwner", fields: [teamId, contentOwnerMembershipId], references: [teamId, id], onDelete: Restrict)
  createdBy          VendorMember                    @relation("TeamTemplateVersionCreatedBy", fields: [vendorId, createdByMemberId], references: [vendorId, id], onDelete: Restrict)
  fieldLocks         TeamFunnelTemplateFieldLock[]
  productSlots       TeamFunnelTemplateProductSlot[]
  partnerFunnelPages PartnerFunnelPage[]

  @@unique([templateId, version])
  @@unique([teamId, id])
  @@unique([vendorId, id])
  @@index([teamId, createdAt])
}

model TeamFunnelTemplateFieldLock {
  id                String          @id @default(cuid())
  vendorId          String
  templateVersionId String
  field             TeamFunnelField
  lockedAt          DateTime        @default(now())
  lockedByMemberId  String

  templateVersion TeamFunnelTemplateVersion @relation(fields: [vendorId, templateVersionId], references: [vendorId, id], onDelete: Cascade)
  lockedBy        VendorMember              @relation(fields: [vendorId, lockedByMemberId], references: [vendorId, id], onDelete: Restrict)

  @@unique([templateVersionId, field])
}

model TeamFunnelTemplateProductSlot {
  id                String   @id @default(cuid())
  vendorId          String
  templateVersionId String
  productId         String
  slotKey           String
  displayOrder      Int      @default(0)
  offerLabel        String?
  createdAt         DateTime @default(now())

  templateVersion  TeamFunnelTemplateVersion    @relation(fields: [vendorId, templateVersionId], references: [vendorId, id], onDelete: Cascade)
  product          Product                      @relation(fields: [vendorId, productId], references: [vendorId, id], onDelete: Restrict)
  partnerOverrides PartnerProductSlotOverride[]

  @@unique([templateVersionId, slotKey])
  @@unique([templateVersionId, displayOrder])
  @@unique([vendorId, id])
  @@index([vendorId, productId])
}

model PartnerFunnelPage {
  id                       String   @id @default(cuid())
  vendorId                 String
  teamId                   String
  templateVersionId        String
  promoterMembershipId     String
  contentOwnerMembershipId String
  liveId                   String?
  slug                     String   @unique
  headline                 String
  subheadline              String?
  body                     String?
  ctaLabel                 String
  ctaUrl                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  vendor                 Vendor                         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  team                   SalesTeam                      @relation(fields: [vendorId, teamId], references: [vendorId, id], onDelete: Cascade)
  templateVersion        TeamFunnelTemplateVersion      @relation(fields: [teamId, templateVersionId], references: [teamId, id], onDelete: Restrict)
  promoter               TeamMembership                 @relation("PartnerPagePromoter", fields: [teamId, promoterMembershipId], references: [teamId, id], onDelete: Restrict)
  contentOwner           TeamMembership                 @relation("PartnerPageContentOwner", fields: [teamId, contentOwnerMembershipId], references: [teamId, id], onDelete: Restrict)
  live                   Live?                          @relation(fields: [vendorId, liveId], references: [vendorId, id], onDelete: Restrict)
  sharing                PartnerFunnelPageShareSetting?
  productOverrides       PartnerProductSlotOverride[]
  clickAttributions      TeamClickAttribution[]
  leadAttributions       TeamLeadAttribution[]
  conversionAttributions TeamConversionAttribution[]

  @@unique([templateVersionId, promoterMembershipId])
  @@unique([vendorId, id])
  @@index([teamId, promoterMembershipId])
}

model PartnerFunnelPageShareSetting {
  id         String             @id @default(cuid())
  pageId     String             @unique
  accessMode TeamPageAccessMode @default(TOKEN_REQUIRED)
  tokenHash  String?            @unique
  expiresAt  DateTime?
  maxUses    Int?
  useCount   Int                @default(0)
  isEnabled  Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  page PartnerFunnelPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([accessMode, isEnabled, expiresAt])
}

model PartnerProductSlotOverride {
  id            String   @id @default(cuid())
  vendorId      String
  pageId        String
  productSlotId String
  productId     String?
  overrideUrl   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  page        PartnerFunnelPage             @relation(fields: [vendorId, pageId], references: [vendorId, id], onDelete: Cascade)
  productSlot TeamFunnelTemplateProductSlot @relation(fields: [vendorId, productSlotId], references: [vendorId, id], onDelete: Cascade)
  product     Product?                      @relation(fields: [vendorId, productId], references: [vendorId, id], onDelete: Restrict)

  @@unique([pageId, productSlotId])
  @@index([productId])
}

model TeamClickAttribution {
  id                       String                @id @default(cuid())
  vendorId                 String
  teamId                   String
  affiliateClickId         String
  pageId                   String?
  leaderMembershipId       String
  promoterMembershipId     String
  contentOwnerMembershipId String
  seminarOwnerMembershipId String?
  source                   TeamAttributionSource
  referralCode             String?
  attributedAt             DateTime              @default(now())

  vendor         Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  team           SalesTeam          @relation(fields: [vendorId, teamId], references: [vendorId, id], onDelete: Cascade)
  affiliateClick AffiliateClick     @relation(fields: [vendorId, affiliateClickId], references: [vendorId, id], onDelete: Cascade)
  page           PartnerFunnelPage? @relation(fields: [pageId], references: [id], onDelete: Restrict)
  leader         TeamMembership     @relation("ClickAttributionLeader", fields: [teamId, leaderMembershipId], references: [teamId, id], onDelete: Restrict)
  promoter       TeamMembership     @relation("ClickAttributionPromoter", fields: [teamId, promoterMembershipId], references: [teamId, id], onDelete: Restrict)
  contentOwner   TeamMembership     @relation("ClickAttributionContentOwner", fields: [teamId, contentOwnerMembershipId], references: [teamId, id], onDelete: Restrict)
  seminarOwner   TeamMembership?    @relation("ClickAttributionSeminarOwner", fields: [teamId, seminarOwnerMembershipId], references: [teamId, id], onDelete: Restrict)

  @@unique([vendorId, affiliateClickId])
  @@index([teamId, promoterMembershipId, attributedAt])
  @@index([teamId, leaderMembershipId, attributedAt])
}

model TeamLeadAttribution {
  id                       String                @id @default(cuid())
  vendorId                 String
  teamId                   String
  formSubmissionId         String                @unique
  pageId                   String?
  leaderMembershipId       String
  promoterMembershipId     String
  contentOwnerMembershipId String
  seminarOwnerMembershipId String?
  source                   TeamAttributionSource
  referralCode             String?
  attributedAt             DateTime              @default(now())

  vendor         Vendor                      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  team           SalesTeam                   @relation(fields: [vendorId, teamId], references: [vendorId, id], onDelete: Cascade)
  formSubmission FormSubmission              @relation(fields: [formSubmissionId], references: [id], onDelete: Cascade)
  page           PartnerFunnelPage?          @relation(fields: [pageId], references: [id], onDelete: Restrict)
  leader         TeamMembership              @relation("LeadAttributionLeader", fields: [teamId, leaderMembershipId], references: [teamId, id], onDelete: Restrict)
  promoter       TeamMembership              @relation("LeadAttributionPromoter", fields: [teamId, promoterMembershipId], references: [teamId, id], onDelete: Restrict)
  contentOwner   TeamMembership              @relation("LeadAttributionContentOwner", fields: [teamId, contentOwnerMembershipId], references: [teamId, id], onDelete: Restrict)
  seminarOwner   TeamMembership?             @relation("LeadAttributionSeminarOwner", fields: [teamId, seminarOwnerMembershipId], references: [teamId, id], onDelete: Restrict)
  conversions    TeamConversionAttribution[]

  @@index([teamId, promoterMembershipId, attributedAt])
  @@index([teamId, leaderMembershipId, attributedAt])
}

model TeamConversionAttribution {
  id                       String                @id @default(cuid())
  vendorId                 String
  teamId                   String
  paymentTransactionId     String
  leadAttributionId        String?
  pageId                   String?
  leaderMembershipId       String
  promoterMembershipId     String
  contentOwnerMembershipId String
  seminarOwnerMembershipId String?
  source                   TeamAttributionSource
  referralCode             String?
  attributedAt             DateTime              @default(now())

  vendor             Vendor               @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  team               SalesTeam            @relation(fields: [vendorId, teamId], references: [vendorId, id], onDelete: Cascade)
  paymentTransaction PaymentTransaction   @relation(fields: [vendorId, paymentTransactionId], references: [vendorId, id], onDelete: Cascade)
  leadAttribution    TeamLeadAttribution? @relation(fields: [leadAttributionId], references: [id], onDelete: Restrict)
  page               PartnerFunnelPage?   @relation(fields: [pageId], references: [id], onDelete: Restrict)
  leader             TeamMembership       @relation("ConversionAttributionLeader", fields: [teamId, leaderMembershipId], references: [teamId, id], onDelete: Restrict)
  promoter           TeamMembership       @relation("ConversionAttributionPromoter", fields: [teamId, promoterMembershipId], references: [teamId, id], onDelete: Restrict)
  contentOwner       TeamMembership       @relation("ConversionAttributionContentOwner", fields: [teamId, contentOwnerMembershipId], references: [teamId, id], onDelete: Restrict)
  seminarOwner       TeamMembership?      @relation("ConversionAttributionSeminarOwner", fields: [teamId, seminarOwnerMembershipId], references: [teamId, id], onDelete: Restrict)

  @@unique([vendorId, paymentTransactionId])
  @@index([teamId, promoterMembershipId, attributedAt])
  @@index([teamId, leaderMembershipId, attributedAt])
  @@index([leadAttributionId])
}
