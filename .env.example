# Local development can use a local Postgres container.
# For Supabase production:
# - DATABASE_URL should be the runtime connection string used by the app.
# - DIRECT_URL should be the direct database connection used by Prisma migrations.
DATABASE_URL="postgresql://postgres:postgres@localhost:54329/celebratedeal_dev?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:54329/celebratedeal_dev?schema=public"

NEXT_PUBLIC_APP_URL="http://localhost:31023"
NODE_ENV="development"
CSRF_SECRET="dev-csrf-secret-123456"
RATE_LIMIT_PROVIDER="memory"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Cloudflare Stream / Stream Live
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_TOKEN=""
CLOUDFLARE_STREAM_WEBHOOK_SECRET=""

# Payment provider
# PayUni ReturnURL / NotifyURL are generated from NEXT_PUBLIC_APP_URL.
# Callback authenticity uses the official EncryptInfo + HashInfo contract.
PAYMENT_PROVIDER="demo"
PAYUNI_ENV="sandbox"
PAYUNI_API_BASE_URL=""
PAYUNI_SANDBOX_QA_ENABLED="false"
PAYUNI_SANDBOX_REFUND_ENABLED="false"
# 必須是經 Vercel inspect 確認非 Production target 的公開 Staging host。
PAYUNI_TEST_APP_URL=""
PAYUNI_STAGING_ALLOWED_HOST=""
PAYUNI_PRODUCTION_APP_HOST="celebratedeal.carry-digital-nomad.in.net"
PAYUNI_TEST_LIVE_PATH="/live/summer-glow-live"
PAYUNI_TEST_CARD_NUMBER=""
PAYUNI_TEST_EXPIRY=""
PAYUNI_TEST_CVV=""
PAYUNI_HASH_KEY=""
PAYUNI_HASH_IV=""
PAYUNI_MERCHANT_ID=""
ECPAY_WEBHOOK_SECRET=""
PAYMENT_WEBHOOK_MAX_RETRIES="5"

# Email / monitoring / analytics
RESEND_API_KEY=""
EMAIL_FROM="CelebrateDeal <no-reply@dev.celebratedeal.local>"
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Jobs
JOB_SECRET="dev-job-secret-123456"

# External smoke tests
TARGET_APP_URL="http://localhost:31023"
SMOKE_TEST_EMAIL=""
SMOKE_VENDOR_ID=""
SMOKE_VENDOR_SLUG=""
RUN_CLOUDFLARE_SMOKE="false"
RUN_DEMO_PAYMENT_WEBHOOK_SMOKE="false"

# One-time platform admin bootstrap
# Used only by `npm run admin:bootstrap`; do not expose these in client code.
PLATFORM_ADMIN_EMAIL="admin@example.com"
PLATFORM_ADMIN_PASSWORD="change-me-with-at-least-12-characters"
PLATFORM_ADMIN_NAME="Platform Admin"
PLATFORM_ADMIN_RESET_PASSWORD="false"
