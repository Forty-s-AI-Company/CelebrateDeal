{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://celebratedeal.local/schemas/qa-issues.schema.json",
  "title": "Untrusted Antigravity QA Issue Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "source", "trustedFields", "issues"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": ["string", "null"], "format": "date-time" },
    "source": { "const": "antigravity" },
    "trustedFields": {
      "const": ["id", "title", "description", "priority", "type", "status"]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "priority", "type", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 80 },
          "title": { "type": "string", "minLength": 1, "maxLength": 300 },
          "description": { "type": "string", "maxLength": 6000 },
          "priority": { "enum": ["P0", "P1", "P2"] },
          "type": { "enum": ["product", "frontend", "ux", "backend", "database-security", "attribution-commission", "test", "security-review", "release"] },
          "status": { "enum": ["open", "confirmed", "resolved", "dismissed"] },
          "prompt": {},
          "validation": {},
          "evidence": {}
        },
        "additionalProperties": true
      }
    }
  }
}
