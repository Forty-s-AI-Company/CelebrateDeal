{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "source", "tasks"],
  "properties": {
    "schemaVersion": {"const": 1},
    "generatedAt": {"type": "string", "format": "date-time"},
    "source": {"const": "reports/ai-team/discovered-issues.json"},
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "priority", "type", "status", "auto_execute", "validation", "write_paths"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Za-z0-9_-]{1,80}$"},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "priority": {"enum": ["P0", "P1", "P2", "P3"]},
          "type": {"enum": ["test", "release"]},
          "status": {"enum": ["ready", "awaiting-human-approval"]},
          "source": {"const": "autonomous-discovery"},
          "affected_files": {"type": "array", "items": {"type": "string"}},
          "write_paths": {"type": "array", "items": {"type": "string"}},
          "validation": {"type": "array", "items": {"type": "string"}},
          "manual_merge_required": {"type": "boolean"},
          "auto_execute": {"type": "boolean"},
          "ignored_control_fields": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    }
  }
}
