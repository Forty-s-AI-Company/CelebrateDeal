{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "stages"],
  "properties": {
    "schemaVersion": {"const": 2},
    "id": {"enum": ["repair", "new-feature"]},
    "name": {"type": "string"},
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "role", "dependsOn"],
        "properties": {
          "id": {"type": "string"},
          "role": {"type": "string"},
          "dependsOn": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
