{
  "name": "celebrate-deal-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 31023",
    "build": "prisma generate && next build",
    "start": "next start --port 31023",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test tests/e2e/smoke.spec.ts --project=chromium-desktop",
    "e2e:a11y": "playwright test tests/e2e/accessibility.spec.ts --project=chromium-desktop",
    "e2e:visual": "playwright test tests/visual --workers=1",
    "e2e:visual:update": "playwright test tests/visual --workers=1 --update-snapshots",
    "lighthouse": "node scripts/lighthouse.mjs",
    "security:secrets": "tsx scripts/secret-scan.ts",
    "security:secrets:staged": "tsx scripts/secret-scan.ts --staged",
    "ai:validate": "python automation/validate_setup.py",
    "ai:smoke": "python automation/validate_setup.py && python automation/orchestrator.py auto-cycle-once",
    "ai:doctor": "python automation/orchestrator.py doctor",
    "ai:inspect": "python automation/orchestrator.py inspect",
    "ai:smoke:codex": "python automation/orchestrator.py smoke-codex",
    "ai:smoke:antigravity": "python automation/orchestrator.py smoke-antigravity",
    "ai:smoke:handoff": "python automation/orchestrator.py smoke-role-handoff",
    "ai:import-qa": "python automation/orchestrator.py import-existing-qa",
    "ai:plan": "python automation/orchestrator.py plan",
    "ai:regression": "python automation/orchestrator.py regression",
    "ai:discover": "python automation/orchestrator.py discover",
    "ai:triage": "python automation/orchestrator.py triage",
    "ai:auto-cycle": "python automation/orchestrator.py auto-cycle",
    "ai:auto-cycle:once": "python automation/orchestrator.py auto-cycle-once",
    "ai:status": "python automation/orchestrator.py status",
    "ai:review": "python automation/orchestrator.py discover --quality",
    "ai:commit": "python automation/orchestrator.py autonomous-commit",
    "ai:qa-loop": "python automation/orchestrator.py smoke-role-handoff",
    "ai:quota:status": "python automation/orchestrator.py quota-status",
    "ai:quota:probe": "python automation/orchestrator.py quota-probe",
    "ai:supervisor": "python automation/orchestrator.py supervisor",
    "ai:resume": "python automation/orchestrator.py resume",
    "automation:test": "python -m unittest discover -s automation -p \"test_*.py\"",
    "quality": "npm run security:secrets && npm run ai:validate && npm run automation:test && npm run lint && npm run typecheck && npm run test && npm run build && npm run preflight",
    "preflight": "tsx scripts/preflight.ts",
    "external:smoke": "tsx scripts/external-smoke.ts",
    "payuni:fixture": "tsx scripts/payuni-webhook-fixtures.ts",
    "cloudflare:fixtures": "tsx scripts/cloudflare-webhook-fixtures.ts",
    "admin:bootstrap": "tsx scripts/bootstrap-platform-admin.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.64.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "lighthouse": "^12.6.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.16"
  }
}
