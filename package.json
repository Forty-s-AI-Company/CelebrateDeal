    "external:smoke": "tsx scripts/external-smoke.ts",
    "payuni:fixture": "tsx scripts/payuni-webhook-fixtures.ts",
    "cloudflare:fixtures": "tsx scripts/cloudflare-webhook-fixtures.ts",
    "admin:bootstrap": "tsx scripts/bootstrap-platform-admin.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
