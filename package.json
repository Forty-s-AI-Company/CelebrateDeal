  "private": true,
  "scripts": {
    "dev": "next dev --port 31023",
    "build": "prisma generate && next build",
    "start": "next start --port 31023",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
